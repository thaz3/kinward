# Public Supabase project identifiers. The publishable key is safe for browser use;
# authorization still depends on verified identity and Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Server-only 32+ character secret used to encrypt the pending verification email.
# Generate separately for each synthetic local/preview environment. Never prefix NEXT_PUBLIC_.
KINWARD_AUTH_COOKIE_SECRET=replace-with-at-least-32-random-characters

# Local executable database tests only. Values are printed by `npm run db:status`.
# Never point these at production, preview, beta, or any database with real information.
KINWARD_TEST_SUPABASE_URL=http://127.0.0.1:54321
KINWARD_TEST_SUPABASE_ANON_KEY=local-anon-key-from-supabase-status
KINWARD_TEST_SUPABASE_SERVICE_ROLE_KEY=local-service-role-key-from-supabase-status
KINWARD_TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
